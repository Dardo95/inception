listen=YES
listen_ipv6=NO

local_root=/var/www/html
anonymous_enable=NO
local_enable=YES
write_enable=YES

local_umask=022
dirmessage_enable=YES
use_localtime=YES

chroot_local_user=YES
allow_writeable_chroot=YES

pasv_enable=YES
pasv_min_port=${FTP_PASV_MIN}
pasv_max_port=${FTP_PASV_MAX}
pasv_address=${HOST_IP}
pasv_addr_resolve=NO

# We will set local_root in entrypoint to /var/www/html
